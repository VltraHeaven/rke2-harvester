kconfig                 = ""
download_image          = true
image_display_name      = ""
image_namespace         = ""
image_storageclass      = "harvester-longhorn"
new_image = {
  name         = "ubuntu24"
  display_name = "noble-server-cloudimg-amd64.img"
  source_type  = "download"
  url          = "https://cloud-images.ubuntu.com/noble/current/noble-server-cloudimg-amd64.img"
}
namespace               = ""
harvester_net           = ""
harvester_net_namespace = ""
vm_prefix               = ""
vm_count                = 1
vm_cpu                  = 4
vm_memory               = "4Gi"
vm_disksize             = "20Gi"
vm_description          = ""
ssh_user                = ""
cloud_config_network_data = ""
cloud_config_user_data  = <<-EOF
    #cloud-config
    package_update: true
    packages:
      - qemu-guest-agent
      - iptables
    runcmd:
      - [systemctl, enable, qemu-guest-agent.service]
      - [systemctl, start, qemu-guest-agent.service]
    users:
    - name: root
      ssh_pwauth: True
      chpasswd: { expire: False }
      ssh_authorized_keys:
        - 
      lock_passwd: false
      shell: /bin/bash
    EOF
